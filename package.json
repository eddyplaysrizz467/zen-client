{
  "name": "zen-client",
  "version": "1.0.11",
  "description": "Zen Client Minecraft launcher rebuilt in JavaScript and Electron.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/generate-icons.js",
    "dist": "npm run icons && electron-builder --win",
    "release": "npm run icons && electron-builder --win"
  },
  "keywords": [
    "minecraft",
    "launcher",
    "electron",
    "javascript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.eddyplaysrizz467.zenclient",
    "productName": "Zen Client",
    "files": [
      "**/*",
      "!dist/**",
      "!out/**",
      "!release/**",
      "!scripts/**",
      "!.github/**",
      "!**/*.map",
      "!**/.git/**",
      "!**/.venv/**",
      "!**/__pycache__/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zen Client"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "eddyplaysrizz467",
        "repo": "zen-client"
      }
    ]
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "discord-rpc": "^4.0.1",
    "pngjs": "^7.0.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^38.2.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8"
  }
}
